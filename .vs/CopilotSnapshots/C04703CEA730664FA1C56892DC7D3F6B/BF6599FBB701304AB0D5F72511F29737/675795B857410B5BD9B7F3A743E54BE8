using api_para_banco.model;
using Microsoft.AspNetCore.Authorization;
using Microsoft.EntityFrameworkCore;

namespace api_para_banco.Services
{
    public class AdmUtilidade
    {
        private readonly EntityFrameWorkModel _context;

        public AdmUtilidade(EntityFrameWorkModel context)
        {
            _context = context;
        }
        
        public async Task<List<ContaPoupanca>> PessoasComCaixinha(string? tipofiltro, string? filtro) 
        {
            var query = _context.ContaPoupanca.Join(_context.ContaCorrente,
                        p => p.Investidor,
                        c => c.Titular,
                        (p, c) => new { p, c });

            switch (tipofiltro) 
            {

                case "valorMinimo":
                    if (decimal.TryParse(filtro, out var min))
                        query = query.Where(x => x.p.Saldo > min);
                    break;
                    
                case "valorMaximo":
                    if (decimal.TryParse(filtro, out var max))
                        query = query.Where(x => x.p.Saldo < max);
                    break;

                case "cpf":
                    query = query.Where(x => x.c.Titular == filtro);
                    break;
            }
            var resultado = await query.Select(x => x.p).ToListAsync();
            return resultado;
        }    
    }
}
